NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here

# PKCE Bridge (ERPNext <-> Supabase)
BRIDGE_SECRET=generate-with-openssl-rand-hex-32
SUPABASE_OAUTH_CLIENT_ID=your-supabase-oauth-app-client-id
SUPABASE_OAUTH_CLIENT_SECRET=your-supabase-oauth-app-client-secret
BRIDGE_BASE_URL=https://your-netlify-domain.netlify.app
BRIDGE_ALLOWED_REDIRECT_URIS=https://your-erpnext.com/api/method/frappe.integrations.oauth2_logins.custom/supabase
